# Tên của Docker Image
IMAGE_NAME=vieneu-tts

# Tag của Docker Image
IMAGE_TAG=latest

# Port ứng dụng (Host)
PORT=7860

# Config cho HuggingFace
# HF_TOKEN=hf_... 

# Config cho System
# UID/GID để mapping quyền file (nếu cần trên Linux)
# USER_ID=1000
# GROUP_ID=1000



HF_HOME=/root/.cache/huggingface
PYTHONUNBUFFERED=1
PHONEMIZER_ESPEAK_LIBRARY=/usr/lib/x86_64-linux-gnu/libespeak-ng.so.1

GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=0

# VieNeu Studio Docker/PWA
# Cloudflare named tunnel token. Configure public hostnames in Cloudflare:
#   tts.example.com -> http://frontend:3000
#   tts.example.com/api/vieneu/* -> http://frontend:3000
# Optional for realtime WebSocket events:
#   tts.example.com/ws/* -> http://server:8000
# TUNNEL_TOKEN=...

# Browser API base. Keep this as a same-origin proxy path for online use.
# The Next.js proxy forwards it to VIENEU_INTERNAL_API_BASE on the server side.
# NEXT_PUBLIC_VIENEU_API_BASE=/api/vieneu
# VIENEU_INTERNAL_API_BASE=http://server:8000
# Optional same-origin WebSocket routing if Cloudflare maps /ws/* to the backend.
# NEXT_PUBLIC_VIENEU_WS_BASE=https://tts.example.com

# Backend CORS origins. The proxy avoids browser CORS for HTTP, but keep this
# if you also expose the backend directly or use direct WebSocket URLs.
# VIENEU_PUBLIC_FRONTEND_ORIGIN=https://tts.example.com

# Optional Docker GPU/build settings.
# TORCH_INSTALL=cu118
# VIENEU_GPUS=all
